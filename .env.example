# Oakline Trend Hunter - settings. Copy this file to ".env.local" and fill in.

# Your Anthropic Claude API key (turns trends into product ideas)
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# Owner login (you). Set these to whatever you want.
OWNER_EMAIL=
OWNER_PASSWORD=
JWT_SECRET=change-this-to-a-long-random-string

# OPTIONAL free key for richer signals (leave blank to skip)
YOUTUBE_API_KEY=

# ONLINE HOSTING ONLY - leave blank when running on your own PC.
# When you deploy (Vercel etc.), set this to your database connection string
# so added users PERSIST and clients can log in 24/7. Format:
#   postgres://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL=

# GOOGLE SHEETS (optional) — auto-create an editable sheet per client.
# Paste the FULL service-account key JSON as one line, and a Shared Drive ID.
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SHARED_DRIVE_ID=
